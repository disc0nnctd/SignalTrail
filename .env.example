TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# Session path is relative to the project root. Do not point this at a path
# outside the repo (e.g. /home/username/...) — that leaks your session location.
TELEGRAM_SESSION_PATH=.cache/telegram.session

# Optional: path to a supplementary key file for Fyers / Alpha Vantage tokens.
# Leave unset if you supply those keys via environment variables directly.
# SIGNALTRAIL_KEY_FILE=/path/to/your/keys.env

# Optional: LLM endpoints (also accepted as CLI flags to evaluate.py)
# HERMES_LLM_VERIFY_ENDPOINT=http://localhost:11434
# HERMES_LLM_VERIFY_MODEL=qwen2.5-7b-local
# HERMES_LLM_EXTRACT_ENDPOINT=https://api.openai.com/v1
# HERMES_LLM_EXTRACT_MODEL=gpt-4.1-mini
# HERMES_LLM_EXTRACT_API_KEY=sk-...
